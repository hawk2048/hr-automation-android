<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_background"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/filter_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Match Score Range -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_match_score"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_match_score_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_match_score_default"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:layout_marginTop="4dp" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/range_slider_match_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:stepSize="1"
                app:values="@array/default_match_score_values"
                app:trackColorActive="@color/primary"
                app:thumbColor="@color/primary"
                app:tickVisible="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_light"
                android:layout_marginVertical="12dp" />

            <!-- Experience Years -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_experience"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_experience_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_experience_default"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:layout_marginTop="4dp" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/range_slider_experience"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="20"
                android:stepSize="1"
                app:values="@array/default_experience_values"
                app:trackColorActive="@color/primary"
                app:thumbColor="@color/primary"
                app:tickVisible="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_light"
                android:layout_marginVertical="12dp" />

            <!-- Education Level -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_education"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

            <Spinner
                android:id="@+id/spinner_education"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/spinner_background"
                android:padding="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_light"
                android:layout_marginVertical="12dp" />

            <!-- Salary Range -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_salary"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

            <Spinner
                android:id="@+id/spinner_salary"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/spinner_background"
                android:padding="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_light"
                android:layout_marginVertical="12dp" />

            <!-- Recent Active -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_recent_active"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

            <Spinner
                android:id="@+id/spinner_recent_active"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/spinner_background"
                android:padding="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_light"
                android:layout_marginVertical="12dp" />

            <!-- Skills Filter (Optional) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_skills"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_skills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/filter_skills_hint"
                    android:inputType="text"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/filter_reset"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apply"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/filter_apply"
            android:backgroundTint="@color/primary" />

    </LinearLayout>

</LinearLayout>
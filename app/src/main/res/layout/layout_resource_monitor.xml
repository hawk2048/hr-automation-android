<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- CPU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="CPU"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <ProgressBar
            android:id="@+id/progress_cpu"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/primary" />

        <TextView
            android:id="@+id/tv_cpu_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textAlignment="center" />
    </LinearLayout>

    <!-- Memory -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="内存"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <ProgressBar
            android:id="@+id/progress_memory"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/accent" />

        <TextView
            android:id="@+id/tv_memory_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textAlignment="center" />
    </LinearLayout>

    <!-- GPU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="GPU"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <ProgressBar
            android:id="@+id/progress_gpu"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/score_excellent" />

        <TextView
            android:id="@+id/tv_gpu_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textAlignment="center" />
    </LinearLayout>

</LinearLayout>
